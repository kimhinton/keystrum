# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
**/node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
# native app separate Next.js build
/native/.next/
/native/out/
/native/next-env.d.ts

# production
/build

# misc
.DS_Store
Thumbs.db
desktop.ini
*.pem
*.bak
*.backup
*.swp
*.swo
*~
*.log

# editor
.idea/

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# claude internal
.claude/

# private rule-table self-assessment metadata (kept on the maintainer's machine, not in the repo)
.oss-rules.json
.oss-rules-*.md

# archives & zips
*.zip

# capture scripts temp
scripts/*.webm
scripts/palette.png
src/components/game/_archive/
src/lib/game/_archive/

# typescript
*.tsbuildinfo
next-env.d.ts

# package manager lockfile (migrated to pnpm)
package-lock.json

# capacitor — commit android/ and ios/ source, ignore per-developer + build + generated
android/local.properties
android/.gradle/
android/.idea/
android/app/build/
android/captures/
android/app/release/
# capacitor regenerates these on `cap sync`:
android/app/src/main/assets/public/
android/app/src/main/assets/capacitor.config.json
android/app/src/main/assets/capacitor.plugins.json
android/capacitor-cordova-android-plugins/

ios/App/Pods/
ios/App/build/
ios/DerivedData/
ios/App/*.xcuserstate
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
# capacitor regenerates these on `cap sync`:
ios/App/App/public/
ios/App/App/capacitor.config.json
ios/App/App/capacitor.plugins.json
ios/capacitor-cordova-ios-plugins/

# CI artifacts downloaded locally (gh run download output)
artifacts/
